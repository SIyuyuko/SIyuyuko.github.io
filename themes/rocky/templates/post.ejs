<html lang="en">

<head>
  <%- include('./includes/head', { siteTitle: `${post.title} - ${themeConfig.siteName}` }) %>
    <meta name="description" content="<%= post.description %>" />
    <meta property="og:title" content="<%= `${post.title} - ${themeConfig.siteName}` %>">
    <meta property="og:description" content="<%= post.description %>" />
    <meta property="og:type" content="articles">
    <meta property="og:url" content="<%= post.link %>" />
    <meta property="og:image"
      content="<%= `${themeConfig.showFeatureImage && post.feature || themeConfig.domain + '/images/avatar.png'}` %>">
    <meta property="og:image:height" content="630">
    <meta property="og:image:width" content="1200">
    <meta name="twitter:title" content="<%= `${post.title} - ${themeConfig.siteName}` %>">
    <meta name="twitter:description" content="<%= post.description %>">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="canonical" href="<%= post.link %>">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/photoswipe.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/default-skin/default-skin.css">

    <% if (site.customConfig.codeHighlight) { %>
      <link rel="stylesheet"
        href="<%= site.themeConfig.domain %>/media/css/prism<%= `-${site.customConfig.hightlightTheme || 'atom-dark'}` %>.css">
      <% } %>

        <% if (site.customConfig.katexRender) { %>
          <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.10.0/katex.min.css">
          <% } %>
</head>

<body>
  <div class="antialiased flex flex-col min-h-screen" id="app">
    <a href="<%= site.themeConfig.domain %>"
      class="fixed top-0 left-0 mt-4 bg-black text-white dark:text-gray-700 dark:bg-yellow-50 dark:hover:bg-black dark:hover:text-white inline-flex p-2 pl-8 hover:text-gray-700 hover:bg-yellow-50 font-bold z-10 transition-fast animated fadeInLeft">
      <%= themeConfig.siteName %>
    </a>
    <div class="max-w-4xl w-full mx-auto">
      <div
        class="shadow-box bg-white dark:bg-gray-600 rounded-lg pt-32 md:pt-64 px-4 md:px-8 pb-8 animated fadeIn mb-8">
        <h1 class="text-5xl font-semibold leading-normal pb-8 mb-8 border-b-8 border-gray-700">
          <%= post.title %>
        </h1>
        <% if (themeConfig.showFeatureImage && post.feature) { %>
          <img src="<%= post.feature %>" alt="<%= post.title %>" class="block w-full mb-8">
          <% } %>
            <div class="mb-8 flex flex-wrap">
              <div class="text-gray-400 text-sm mr-4">
                <%= post.dateFormat %> · <%= post.stats.text %>
              </div>
              <% post.tags.forEach(function(tag) { %>
                <a href="<%= tag.link %>"
                  class="text-gray-700 text-sm border-b-2 border-dotted border-gray-200 hover:border-gray-600 transition-all duration-100 inline-flex mr-2">
                  <i class="ri-hashtag"></i>
                  <%= tag.name %>
                </a>
                <% }); %>
            </div>
            <div class="markdown mb-8" v-pre>
              <%- post.content %>
            </div>
            <!-- Share to Twitter, Weibo, Telegram -->
            <div class="flex items-center">
              <div id="shareBtn"
                class="px-4 flex items-center text-gray-500 hover:bg-blue-100 dark:hover:bg-gray-600 inline-flex"
                @click="shareCustom" title="分享本页">
                <i class="ri-share-forward-line"></i>
              </div>
            </div>
      </div>

      <% if (typeof commentSetting !=='undefined' && commentSetting.showComment) { %>
        <% if (commentSetting.commentPlatform==='gitalk' ) { %>
          <div id="gitalk-container"></div>
          <% } %>

            <% if (commentSetting.commentPlatform==='disqus' ) { %>
              <%- include('./includes/disqus') %>
                <% } %>
                  <% } %>

                    <% if (site.customConfig.openValine) { %>
                      <div id="vlaine-comment"></div>
                      <% } %>

                        <%- include('./includes/footer') %>
    </div>

    <!-- TOC Container -->
    <div id="tocOpen"
      class="fixed right-0 bottom-0 mb-16 mr-4 shadow w-8 h-8 rounded-full flex justify-center items-center z-10 cursor-pointer bg-white dark:bg-gray-500 dark:text-gray-200 hover:shadow-lg transition-all animated fadeInRight"
      @click="showToc = true">
      <i class="ri-file-list-line"></i>
    </div>

    <div id="tocClose"
      class="fixed right-0 top-0 bottom-0 overflow-y-auto w-64 bg-white dark:bg-gray-800 p-4 border-l border-gray-100 dark:border-gray-600 z-10 transition-fast"
      :class="{ '-mr-64': !showToc }">
      <div class="flex mb-4 justify-end">
        <div id="closeBtn"
          class="w-8 h-8 inline-flex justify-center items-center rounded-full cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-600 transition-fast"
          @click="showToc = false">
          <i class="ri-close-line text-lg"></i>
        </div>
      </div>
      <div class="post-toc-container">
        <%- post.toc %>
      </div>
    </div>

    <!-- Back to top -->
    <div id="backBtn"
      class="fixed right-0 bottom-0 mb-4 mr-4 shadow w-8 h-8 rounded-full flex justify-center items-center z-10 cursor-pointer bg-white hover:shadow-lg transition-all dark:bg-gray-500 dark:text-gray-200"
      @click="backToUp" v-show="scrolled">
      <i class="ri-arrow-up-line"></i>
    </div>
  </div>

  <%- include('./includes/photoswipe') %>

    <script src="https://cdn.jsdelivr.net/npm/vue/dist/vue.js"></script>
    <script src="<%= site.themeConfig.domain %>/media/scripts/main.js"></script>
    <script src="<%= site.themeConfig.domain %>/media/scripts/img.js"></script>
    <script src="<%= site.themeConfig.domain %>/media/scripts/all-pjax.js"></script>

    <!-- Code Highlight -->
    <% if (site.customConfig.codeHighlight) { %>
      <script src="<%= site.themeConfig.domain %>/media/prism.js"></script>
      <script>
        Prism.highlightAll()
      </script>
      <% } %>

        <script src="https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/photoswipe.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/photoswipe-ui-default.min.js"></script>
        <script>
          //初始化
          initImg();
          window.onload = function () {
            aplayerbtnInit();
          };
        </script>
        <script type="application/javascript" src="https://cdn.bootcss.com/jquery/3.4.1/jquery.min.js"></script>
        <script type="application/javascript"
          src="https://cdn.bootcss.com/jquery.pjax/2.0.1/jquery.pjax.min.js"></script>
        <script>
          // 对所有链接跳转事件绑定pjax容器container
          $(document).pjax('a[target!=_blank]', '#app', { fragment: '#app', timeout: 8000 }).on('pjax:complete', function () {
            // 需要重载的 JS 函数
            if (window.location.href.includes("post")) {
              console.log("pjax mode on");
              let url = decodeURIComponent(window.location.href);
              initImg();
              navOnScroll();
              backToUp();
              tocManage();
              shareCustom(url);
            } else {
              showMenu();
            }
          }).on('pjax:start', function (event) {
            // 需要重载的 JS 文件
            $.getScript("https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/photoswipe.min.js");
            $.getScript("https://cdn.jsdelivr.net/npm/photoswipe@4.1.3/dist/photoswipe-ui-default.min.js");
            $.getScript("<%= site.themeConfig.domain %>/media/scripts/all-pjax.js");
            $.getScript("<%= site.themeConfig.domain %>/media/scripts/img.js");
          });
        </script>
        </script>
        <% if (site.customConfig.openValine) { %>
          <%- include('./includes/valine') %>
            <% } %>
              <% if (typeof commentSetting !=='undefined' && commentSetting.showComment) { %>
                <% if (commentSetting.commentPlatform==='gitalk' ) { %>
                  <%- include('./includes/gitalk') %>
                    <% } %>
                      <% } %>
                        <%if(site.customConfig.aplayerchoice){%>
                          <%- include('./includes/aplayer') %>
                            <%}%>
</body>

</html>